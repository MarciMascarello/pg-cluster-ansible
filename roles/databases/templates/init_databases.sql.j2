-- =============================================================================
-- PostgreSQL HA Cluster — Database Initialization Script
-- Generated by Ansible on {{ ansible_date_time.iso8601 }}
-- Node: {{ inventory_hostname }}
-- =============================================================================
\set ON_ERROR_STOP on

{% for db in databases %}
-- =============================================================================
-- DATABASE: {{ db.name }}
-- =============================================================================

-- Tablespace (idempotent via \gexec)
SELECT 'CREATE TABLESPACE ts_{{ db.name }} LOCATION ''/pgdata/{{ db.name }}'''
WHERE NOT EXISTS (SELECT FROM pg_tablespace WHERE spcname = 'ts_{{ db.name }}')
\gexec

-- Database (idempotent via \gexec)
SELECT 'CREATE DATABASE {{ db.name }} TABLESPACE ts_' || '{{ db.name }}'
WHERE NOT EXISTS (SELECT FROM pg_database WHERE datname = '{{ db.name }}')
\gexec

{% for user in db.users %}
-- User: {{ user.name }} ({{ user.role }})
DO $body$
BEGIN
  IF NOT EXISTS (SELECT FROM pg_roles WHERE rolname = '{{ user.name }}') THEN
    CREATE ROLE {{ user.name }} WITH LOGIN PASSWORD '{{ db.passwords[user.name] }}';
    RAISE NOTICE 'Role {{ user.name }} created.';
  ELSE
    ALTER ROLE {{ user.name }} WITH LOGIN PASSWORD '{{ db.passwords[user.name] }}';
    RAISE NOTICE 'Role {{ user.name }} already exists, password updated.';
  END IF;
END $body$;

GRANT CONNECT ON DATABASE {{ db.name }} TO {{ user.name }};
{% if user.role == 'admin' %}
GRANT ALL PRIVILEGES ON DATABASE {{ db.name }} TO {{ user.name }};
{% endif %}

{% endfor %}
{% endfor %}
